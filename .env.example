# Базовый публичный URL сайта (без слэша в конце) — для canonical и Open Graph.
PUBLIC_SITE_URL="https://example.com"

# Дата и время старта первого сезона (ISO 8601, с указанием часового пояса).
PUBLIC_SEASON_START="2026-07-01T12:00:00+03:00"

# Ссылка на сообщество в Telegram.
PUBLIC_TELEGRAM_URL="https://t.me/your_community"

# Username Telegram-бота авторизации (без @) — для Login Widget.
PUBLIC_TELEGRAM_BOT_USERNAME="your_bot"

# --- Приватные (только сервер, без префикса PUBLIC_) ---

# Подключение к MySQL (формат: mysql://user:password@host:port/database).
DATABASE_URL="mysql://root:password@127.0.0.1:3306/zombieland"

# Подключение к Redis (формат: redis://[:password@]host:port[/db]).
REDIS_URL="redis://127.0.0.1:6379"

# Токен Telegram-бота (от @BotFather) — для проверки подписи Login Widget.
TELEGRAM_BOT_TOKEN="123456789:your-bot-token"

# Секрет для защищённого запуска cron-эндпоинтов /api/cron/*.
CRON_SECRET="generate-a-long-random-string"

# ID/username канала для постов бота (бот должен быть админом канала).
TELEGRAM_CHANNEL_ID="@your_channel"

# Секрет для верификации входящих webhook-запросов Telegram.
TELEGRAM_WEBHOOK_SECRET="generate-a-long-random-string"

# --- Платёжный шлюз Platega ---
PLATEGA_BASE_URL="https://app.platega.io"
PLATEGA_MERCHANT_ID="your-merchant-id"
PLATEGA_SECRET="your-api-secret"
# Метод оплаты: 2 — СБП QR.
PLATEGA_METHOD="2"

# Integration Token проекта Hawk (логгер ошибок). Пусто — логирование выключено.
HAWK_TOKEN=""
